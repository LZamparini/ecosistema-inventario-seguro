# ──────────────────────────────────────────────
# Plantilla de Configuración del Entorno (Copiar a .env)
# ──────────────────────────────────────────────

# Modo de autenticación: 'ldap' (Active Directory) o 'local' (usuarios mock en auth.py)
AUTH_MODE=local

# Configuración LDAP / Active Directory (Requerido solo si AUTH_MODE=ldap)
LDAP_HOST=127.0.0.1
LDAP_PORT=389
LDAP_USE_SSL=false
AD_DOMAIN=dominio.local
AD_BASE_DN=DC=dominio,DC=local
LDAP_BIND_USER=usuario_lectura@dominio.local
LDAP_BIND_PASSWORD=contrasena_segura
LDAP_TIMEOUT=10
AD_DEFAULT_ROLE=alumno

# Configuración SQL Server
SQL_SERVER_HOST=127.0.0.1
SQL_SERVER_PORT=1433
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=tu_contrasena_sql
SQL_SERVER_DATABASE=ubicacion_db

# Clave secreta de Flask para firma de sesiones (Generar una aleatoria en producción)
SECRET_KEY=clave-secreta-desarrollo-inventario-seguro
