# Modo de autenticación: 'ldap' (Active Directory) o 'local'
AUTH_MODE=local

# Configuración LDAP / Active Directory
LDAP_HOST=127.0.0.1
LDAP_PORT=389
LDAP_USE_SSL=false
AD_DOMAIN=dominio.local
AD_BASE_DN=DC=dominio,DC=local
LDAP_BIND_USER=
LDAP_BIND_PASSWORD=
LDAP_TIMEOUT=10
AD_DEFAULT_ROLE=alumno

# Configuración SQL Server
SQL_SERVER_HOST=127.0.0.1
SQL_SERVER_PORT=1433
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=
SQL_SERVER_DATABASE=ubicacion_db

# Configuración MongoDB (componentes de hardware)
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DATABASE=inventario
MONGO_USER=root
MONGO_PASSWORD=

# Clave secreta de Flask para firma de cookies de sesión
SECRET_KEY=clave-secreta-cambiar-en-produccion
